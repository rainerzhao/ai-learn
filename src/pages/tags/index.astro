---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/paths';
import { isPublishableArticleId } from '../../lib/content-filters';

const articles = await getCollection('articles', ({ id }) => isPublishableArticleId(id));

const tagMap = new Map<string, number>();
for (const article of articles) {
  const tags = article.data.tags || [];
  for (const tag of tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签" description="按标签浏览 AI 基础设施知识库">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold mb-6" style="color: var(--text-primary)">标签索引</h1>

    {sortedTags.length === 0 ? (
      <p style="color: var(--text-muted)">暂无标签</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {sortedTags.map(([tag, count]) => (
          <a
            href={withBase(`/tags/${encodeURIComponent(tag)}/`)}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:scale-105"
            style="background: var(--bg-card); border: 1px solid var(--border); color: var(--accent)"
          >
            {tag}
            <span class="text-xs" style="color: var(--text-muted)">{count}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
