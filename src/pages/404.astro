---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4" data-pagefind-ignore>
    <div class="text-8xl font-bold mb-4" style="color: var(--accent)">404</div>
    <h1 class="text-2xl font-bold mb-2" style="color: var(--text-primary)">页面未找到</h1>
    <p class="mb-8" style="color: var(--text-secondary)">你访问的页面不存在或已被移动</p>
    <a
      href="/"
      class="px-6 py-3 rounded-lg font-medium transition-all hover:opacity-90 hover:-translate-y-0.5"
      style="background: var(--accent); color: #fff"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
